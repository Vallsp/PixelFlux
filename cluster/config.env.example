# Deployment config for the GitOps bring-up (task k3s:up / task k3d:up).
# Copy this file to cluster/config.env and set your values:
#
#   cp cluster/config.env.example cluster/config.env
#
# config.env is gitignored, so your real domain/email never land in the repo.
# These are NOT secrets — just per-deployment settings. You can also pass them
# as environment variables, which take precedence:
#   DOMAIN=mydomain.com ACME_EMAIL=me@mydomain.com task k3s:up

# The domain Traefik routes to. The apex and its www. subdomain are both used,
# so make sure both have an A record pointing at the cluster's public IP.
DOMAIN=domain.com

# Contact address Let's Encrypt uses for certificate-expiry notices.
ACME_EMAIL=toto@toto.com
