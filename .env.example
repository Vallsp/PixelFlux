# Local k3d bootstrap secrets. Copy to .env (which is gitignored — NEVER commit
# the filled-in file). Only used by `task k3d:up` to create cluster secrets;
# nothing here is read by the app itself.

# GitHub username + a classic PAT with the `read:packages` scope.
# Used to pull the private ghcr.io/vallsp/pixelflux image.
GHCR_USER=your-github-username
GHCR_PAT=ghp_replace_me

# SSH private key registered as a read-only deploy key on the repo (its public
# half must already be added on GitHub). Used for Argo CD's git access.
DEPLOY_KEY_PATH=~/.ssh/pixelflux-argocd-deploy
